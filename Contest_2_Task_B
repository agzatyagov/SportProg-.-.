#include <iostream>
#include <string>
#include <vector>
using namespace std;
 
int main() {
    string s;
    cin >> s;
    int n = s.size();
 
    vector<int> z(n, 0);
    z[0] = n;
    int l = 0, r = 0;
    for (int i = 1; i < n; i++) {
        if (i < r) {
            z[i] = min(r - i, z[i - l]);
        }
        while (i + z[i] < n && s[z[i]] == s[i + z[i]]) {
            z[i]++;
        }
        if (i + z[i] > r) {
            l = i;
            r = i + z[i];
        }
    }
 
    int ans = n;
    for (int p = 1; p < n; p++) {
        if (n % p == 0 && z[p] == n - p) {
            ans = p;
            break;
        }
    }
 
    cout << ans << endl;
    return 0;
}
