#include <stdio.h>
 
#define MAXN 200005
 
int parent[MAXN];
int sum[MAXN];
char s[MAXN];
 
int main() {
    int t;
    scanf("%d", &t);
 
    while (t--) {
        int n;
        scanf("%d", &n);
 
        for (int i = 2; i <= n; i++) {
            scanf("%d", &parent[i]);
        }
 
        scanf("%s", s + 1);
 
        for (int i = 1; i <= n; i++) {
            if (s[i] == 'W') sum[i] = 1;
            else sum[i] = -1;
        }
 
        for (int i = n; i >= 2; i--) {
            sum[parent[i]] += sum[i];
        }
 
        int ans = 0;
        for (int i = 1; i <= n; i++) {
            if (sum[i] == 0) ans++;
        }
 
        printf("%d\n", ans);
    }
 
    return 0;
}
