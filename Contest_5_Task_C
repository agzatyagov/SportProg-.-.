#include <iostream>
#include <algorithm>
using namespace std;
 
int profit[105][105];
int dp[105][105];
 
int main() {
    int T;
    cin >> T;
 
    while (T--) {
        int n, m;
        cin >> n >> m;
 
        for (int i = 1; i <= n; i++) {
            profit[i][0] = 0;
            for (int j = 1; j <= m; j++) {
                cin >> profit[i][j];
            }
        }
 
        for (int i = 0; i <= n; i++)
            for (int j = 0; j <= m; j++)
                dp[i][j] = 0;
 
        for (int i = 1; i <= n; i++) {
            for (int j = 0; j <= m; j++) {
                for (int k = 0; k <= j; k++) {
                    dp[i][j] = max(dp[i][j], dp[i - 1][j - k] + profit[i][k]);
                }
            }
        }
        cout << dp[n][m] << '\n';
    }
    return 0;
}
